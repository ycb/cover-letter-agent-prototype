# Cover Letter Agent Environment Configuration
# Copy this file to .env and fill in your actual values

# OpenAI API Configuration (Required for LLM enhancement)
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Google Drive Integration (Optional)
# Download credentials.json from Google Cloud Console
GOOGLE_CREDENTIALS_FILE=credentials.json
GOOGLE_FOLDER_ID=your-google-drive-folder-id
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com

# Application Configuration (Optional)
# Set to 'production' for stricter security checks
ENVIRONMENT=development

# Logging Configuration (Optional)
LOG_LEVEL=INFO
LOG_FILE=cover_letter_agent.log

# Performance Configuration (Optional)
CACHE_ENABLED=true
CACHE_MAX_SIZE=1000
CACHE_TTL_HOURS=24

# Security Configuration (Optional)
SECURITY_AUDIT_ENABLED=true
SECURITY_SCAN_ON_STARTUP=true
